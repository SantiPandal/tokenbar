{
  "name": "tokenbar",
  "version": "0.1.0",
  "description": "Native macOS menu bar token counter for local Codex and Claude logs.",
  "license": "MIT",
  "author": "Santiago Pandal",
  "homepage": "https://github.com/SantiPandal/tokenbar#readme",
  "repository": {
